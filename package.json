{
  "name": "@shepherd-terminal/chopper",
  "version": "0.1.0",
  "description": "CLI tool for cryptocurrency trade analysis - best trades, oracle bounds, and drawdown analysis",
  "type": "module",
  "bin": {
    "chopper": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "prepare": "git config core.hooksPath .githooks"
  },
  "keywords": [
    "crypto",
    "trading",
    "analysis",
    "drawdown",
    "ccxt",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ccxt": "^4.4.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
